  "keyFeatures": [
    "Multi-platform video downloads from TikTok, Instagram, YouTube, Facebook, Twitter/X, and 1000+ sites",
    "TikTok downloads without watermark in HD quality via TikWM API",
    "Server-side stream proxy for bypassing CDN blocks on mobile and web",
    "Real-time download progress via Server-Sent Events (SSE)",
    "React Native / Expo integration with native progress bar support",
    "Zero-disk streaming — no video data stored beyond auto-cleanup TTL",
    "YouTube cookie support to bypass bot detection",
    "CORS-enabled for web browsers, mobile apps, and Expo Go"
  ],
  "publicApiSurface": [
    "POST /api/metadata",
    "POST /api/get-direct-url",
    "GET /api/stream",
    "GET /api/tiktok/info",
    "POST /api/proxy-stream",
    "POST /api/server-stream",
    "POST /api/download/start",
    "GET /api/download/progress/{download_id}",
    "GET /api/download/file/{download_id}",
    "GET /api/thumbnail"
  ]
